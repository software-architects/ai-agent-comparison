{
  "$schema": "https://biomejs.dev/schemas/2.4.15/schema.json",
  "formatter": {
    "enabled": true,
    "indentStyle": "space"
  },
  "linter": {
    "enabled": true
  },
  "files": {
    "includes": [
      "**",
      "!**/.next",
      "!**/coverage",
      "!**/dist",
      "!**/node_modules",
      "!**/playwright-report",
      "!**/test-results"
    ]
  },
  "javascript": {
    "formatter": {
      "quoteStyle": "double",
      "semicolons": "always"
    }
  }
}
