{
  "name": "nextjs-application-skeleton",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=20.9.0"
  },
  "scripts": {
    "build": "pnpm -r --if-present run build",
    "dev": "pnpm --filter web dev",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "outdated": "pnpm outdated",
    "test": "pnpm --filter web exec playwright install chromium && pnpm -r --if-present run test",
    "typecheck": "pnpm -r --if-present run typecheck",
    "e2e": "pnpm --filter web exec playwright install chromium && pnpm --filter web run e2e"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.15"
  }
}
