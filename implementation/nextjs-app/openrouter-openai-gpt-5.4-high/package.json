{
  "name": "nextjs-application-skeleton",
  "private": true,
  "packageManager": "pnpm@11.1.3",
  "scripts": {
    "build": "pnpm -r --if-present build",
    "console": "pnpm --filter @workspace/console start",
    "dev": "pnpm --filter @workspace/web dev",
    "e2e": "pnpm --filter @workspace/web e2e",
    "format": "biome format --write .",
    "lint": "biome lint .",
    "outdated": "pnpm outdated -r",
    "postinstall": "pnpm --filter @workspace/web exec playwright install chromium",
    "start": "pnpm --filter @workspace/web start",
    "test": "pnpm -r --if-present test",
    "typecheck": "pnpm -r --if-present typecheck"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@types/node": "^25.9.0",
    "typescript": "^6.0.3"
  }
}
