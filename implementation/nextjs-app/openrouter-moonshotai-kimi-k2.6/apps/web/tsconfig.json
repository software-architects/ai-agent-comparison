{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"target": "ES2017",
		"module": "ESNext",
		"moduleResolution": "bundler",
		"jsx": "preserve",
		"allowJs": true,
		"noEmit": true,
		"incremental": true,
		"resolveJsonModule": true,
		"isolatedModules": true,
		"composite": false,
		"plugins": [
			{
				"name": "next"
			}
		],
		"paths": {
			"@/*": ["./src/*"]
		}
	},
	"include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
	"exclude": ["node_modules", "**/*.test.ts", "**/*.test.tsx", "e2e"]
}
