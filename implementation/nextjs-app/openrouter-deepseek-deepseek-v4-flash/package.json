{
  "name": "nextjs-app",
  "private": true,
  "scripts": {
    "dev": "pnpm --filter @repo/web dev",
    "lint": "biome lint .",
    "format": "biome check --formatter-enabled=true --linter-enabled=false .",
    "format:fix": "biome check --write --formatter-enabled=true --linter-enabled=false .",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test",
    "e2e": "playwright test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.15",
    "@playwright/test": "^1.60.0",
    "@vitest/browser": "^4.1.7",
    "typescript": "^6.0.3",
    "vitest": "^4.1.7",
    "vitest-browser-react": "^2.2.0"
  },
  "packageManager": "pnpm@11.1.3",
  "engines": {
    "node": ">=24.0.0"
  }
}
